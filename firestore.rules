rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Core Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailAdmin() { return isSignedIn() && request.auth.token.email == 'souturbo149@gmail.com' && request.auth.token.email_verified == true; }
    function isAdmin() { return isEmailAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid))); }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation Blueprint for the User Profile Entity
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'xp', 'level', 'plan', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 255 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.xp is number && data.xp >= 0 &&
             data.level is number && data.level >= 1 &&
             data.plan is string && data.plan in ['free', 'iron', 'gold', 'diamante'] &&
             (data.createdAt == request.time || data.createdAt is timestamp); // Fallback for existing docs
    }

    match /users/{userId} {
      // Read access: Only the owner or admin can GET documents
      // We use isOwner(userId) first as it's the most common case and has no DB overhead
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      
      // List access: ONLY admins can list ALL users
      // Note: We use isEmailAdmin() here to avoid exists() in list queries per Pillar 8
      allow list: if isEmailAdmin();
      
      // Creation restricted to exact schema using validation bluepring
      allow create: if isOwner(userId) && 
                       isValidId(userId) && 
                       incoming().uid == userId && 
                       isValidUser(incoming());
                       
      // Update action: Client is only allowed to update their XP and Level. 
      // Admins can update EVERYTHING including the plan.
      allow update: if (isOwner(userId) || isAdmin()) &&
                       isValidId(userId) &&
                       incoming().uid == userId && (
                         isAdmin() || (
                           incoming().xp is number && incoming().xp >= existing().xp &&
                           incoming().level is number && incoming().level >= existing().level &&
                           incoming().plan == existing().plan &&
                           incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level'])
                         )
                       );
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // System provisioned only
    }
  }
}
