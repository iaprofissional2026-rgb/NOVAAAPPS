rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Core Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.lower() == 'souturbo149@gmail.com' ||
        request.auth.token.email.lower() == 'souturbo149@app.evomind' ||
        request.auth.token.email.lower().startsWith('novaaapsadmin') ||
        request.auth.token.email.lower().startsWith('novaappsadmin')
      );
    }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation Blueprint for the User Profile Entity
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'displayName', 'xp', 'level', 'plan', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128 &&
             data.username is string && data.username.size() >= 1 &&
             data.email is string && data.email.size() <= 255 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.xp is number && data.xp >= 0 &&
             data.level is number && data.level >= 1 &&
             data.plan is string && data.plan in ['free', 'iron', 'gold', 'diamante'] &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(userId) && 
                       isValidId(userId) && 
                       incoming().uid == userId && 
                       isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) &&
                       isValidId(userId) &&
                       incoming().uid == userId && (
                         isAdmin() || (
                           incoming().xp is number && incoming().xp >= existing().xp &&
                           incoming().level is number && incoming().level >= existing().level &&
                           incoming().plan == existing().plan &&
                           incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level'])
                         )
                       );
    }

    // NEW: App Configuration (Colors, Phrases, Music)
    match /config/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NEW: Missions System
    match /missions/{missionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
